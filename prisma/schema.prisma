generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Trip {
  id            String   @id @default(uuid())
  userId        String
  destination   String
  days          Int
  itineraryData Json
  createdAt     DateTime @default(now())
}
